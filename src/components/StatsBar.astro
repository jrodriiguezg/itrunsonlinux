---
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../db/schema';
import { env } from 'cloudflare:workers';
import { sql } from 'drizzle-orm';
import { getLanguage, useTranslations } from '../i18n';

const db = drizzle(env.DB, { schema });
const lang = getLanguage(Astro.request, Astro.cookies);
const t = useTranslations(lang);

const totalApps = await db.select({ count: sql<number>`count(*)` }).from(schema.apps).get();
const nativeApps = await db.select({ count: sql<number>`count(*)` }).from(schema.apps).where(
  sql`${schema.apps.linuxAlternative} LIKE '%Native%'`
).get();
const categories = await db.select({ count: sql<number>`count(DISTINCT ${schema.apps.category})` }).from(schema.apps).get();
---

<div class="stats-bar">
  <div class="stat-item">
    <span class="stat-number">{totalApps?.count || 0}</span>
    <span class="stat-label">{t('stats.totalApps')}</span>
  </div>
  <div class="stat-divider"></div>
  <div class="stat-item">
    <span class="stat-number stat-native">{nativeApps?.count || 0}</span>
    <span class="stat-label">{t('stats.nativeApps')}</span>
  </div>
  <div class="stat-divider"></div>
  <div class="stat-item">
    <span class="stat-number">{categories?.count || 0}</span>
    <span class="stat-label">{t('stats.categories')}</span>
  </div>
</div>

<style>
  .stats-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 1.25rem 2rem;
    background-color: var(--surface-color);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    margin-bottom: 2.5rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--text-color);
    letter-spacing: -0.5px;
  }

  .stat-native {
    color: #10b981;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background-color: var(--border-color);
  }

  @media (max-width: 768px) {
    .stats-bar {
      gap: 1rem;
      padding: 1rem 1.25rem;
    }

    .stat-number {
      font-size: 1.25rem;
    }

    .stat-label {
      font-size: 0.7rem;
    }
  }
</style>
