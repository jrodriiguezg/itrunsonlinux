---
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../db/schema';
import { env } from 'cloudflare:workers';
import { isWebApp } from '../utils/webapp';
import { getLanguage, useTranslations } from '../i18n';

const db = drizzle(env.DB, { schema });
const lang = getLanguage(Astro.request, Astro.cookies);
const t = useTranslations(lang);

const allApps = (await db.select().from(schema.apps).all()).map(app => ({
  ...app,
  isWebApp: isWebApp(app)
}));
---

<div style="max-width: 600px; margin: 0 auto 3.5rem auto; position: relative;">
    <input 
        type="text" 
        id="search-input" 
        placeholder={t('search.placeholder')}
        autocomplete="off"
        style="width: 100%; padding: 1.1rem 1.4rem; font-size: 1.05rem; border-radius: 8px; border: 1px solid var(--border-color); background-color: var(--surface-color); color: var(--text-color); outline: none; transition: border-color 0.15s ease;"
        onfocus="this.style.borderColor='var(--text-color)'"
        onblur="this.style.borderColor='var(--border-color)'"
    />
    
    <!-- Search Filter Pills -->
    <div style="display: flex; gap: 0.5rem; margin-top: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <button type="button" class="search-pill active" data-filter="all">🔍 {lang === 'en' ? 'All' : 'Todo'}</button>
        <button type="button" class="search-pill" data-filter="native">🐧 {lang === 'en' ? 'Native' : 'Nativo'}</button>
        <button type="button" class="search-pill" data-filter="webapp">☁️ Web Apps</button>
        <button type="button" class="search-pill" data-filter="wine">⚙️ Wine / Proton</button>
    </div>
    
    <div 
        id="search-results" 
        style="display: none; position: absolute; top: calc(100% + 0.5rem); left: 0; right: 0; background-color: var(--surface-color); border: 1px solid var(--border-color); border-radius: 8px; box-shadow: var(--card-shadow-hover); z-index: 10; max-height: 350px; overflow-y: auto;"
    >
    </div>
</div>

<script define:vars={{ 
    apps: allApps,
    tAlternativeText: t('search.alternative'),
    tNoResults: t('search.noResults'),
    tRequestToAdd: t('search.request')
}}>
    const searchInput = document.getElementById('search-input');
    const resultsContainer = document.getElementById('search-results');
    const pills = document.querySelectorAll('.search-pill');
    let activeFilter = 'all';

    pills.forEach(pill => {
        pill.addEventListener('click', () => {
            pills.forEach(p => p.classList.remove('active'));
            pill.classList.add('active');
            activeFilter = pill.getAttribute('data-filter') || 'all';
            
            // Re-trigger search logic
            const event = new Event('input', { bubbles: true });
            searchInput.dispatchEvent(event);
        });
    });

    searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        
        if (query.length < 2) {
            resultsContainer.style.display = 'none';
            return;
        }

        const filtered = apps.filter(app => {
            const matchesQuery = app.name.toLowerCase().includes(query) || 
                                 app.description.toLowerCase().includes(query) ||
                                 (app.alternativeTo && app.alternativeTo.toLowerCase().includes(query));
            if (!matchesQuery) return false;

            const isNative = app.linuxAlternative && app.linuxAlternative.toLowerCase().includes('native');
            
            if (activeFilter === 'native') {
                return isNative;
            } else if (activeFilter === 'webapp') {
                return app.isWebApp;
            } else if (activeFilter === 'wine') {
                return !isNative && !app.isWebApp;
            }
            return true;
        }).slice(0, 5);

        resultsContainer.innerHTML = '';
        
        if (filtered.length > 0) {
            filtered.forEach(app => {
                const a = document.createElement('a');
                a.href = `/app/${app.id}`;
                a.style.cssText = 'display: block; padding: 1.1rem 1.4rem; border-bottom: 1px solid var(--border-color); color: var(--text-color); text-decoration: none; transition: background-color 0.15s ease;';
                a.onmouseover = () => a.style.backgroundColor = 'var(--surface-hover)';
                a.onmouseout = () => a.style.backgroundColor = 'transparent';
                
                let alternativeText = '';
                if (app.alternativeTo && app.alternativeTo.toLowerCase().includes(query) && !app.name.toLowerCase().includes(query)) {
                    alternativeText = `<span style="font-size: 0.7rem; background-color: var(--bg-color); color: #10b981; padding: 0.15rem 0.4rem; border-radius: 4px; margin-left: 0.5rem; border: 1px solid rgba(16, 185, 129, 0.2); font-family: 'Space Grotesk', sans-serif; font-weight: 700; text-transform: uppercase;">${tAlternativeText}</span>`;
                }
                
                const isNative = app.linuxAlternative && app.linuxAlternative.toLowerCase().includes('native');
                const nativeTag = isNative ? `<span style="font-size: 0.65rem; background-color: var(--bg-color); color: #10b981; padding: 0.15rem 0.4rem; border-radius: 4px; border: 1px solid rgba(16, 185, 129, 0.2); font-weight: 700; margin-left: 0.5rem; font-family: 'Space Grotesk', sans-serif; text-transform: uppercase;"><i class="fa-brands fa-linux"></i> Native</span>` : '';
                const webAppTag = app.isWebApp ? `<span style="font-size: 0.65rem; background-color: var(--bg-color); color: #3b82f6; padding: 0.15rem 0.4rem; border-radius: 4px; border: 1px solid rgba(59, 130, 246, 0.2); font-weight: 700; margin-left: 0.5rem; font-family: 'Space Grotesk', sans-serif; text-transform: uppercase;"><i class="fa-solid fa-cloud"></i> Web App</span>` : '';
                
                a.innerHTML = `
                    <div style="font-weight: 700; margin-bottom: 0.25rem; display: flex; align-items: center; font-family: 'Space Grotesk', sans-serif; font-size: 1.05rem;">
                        ${app.name}
                        ${alternativeText}
                        ${nativeTag}
                        ${webAppTag}
                    </div>
                    <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: 500;">${app.category}</div>
                `;
                resultsContainer.appendChild(a);
            });
            resultsContainer.style.display = 'block';
        } else {
            const div = document.createElement('div');
            div.style.cssText = 'padding: 1.5rem; color: var(--text-muted); text-align: center; font-size: 0.95rem;';
            div.innerHTML = `${tNoResults}<br><br><a href="https://github.com/jrodriiguezg/itrunsonlinux/issues/new" target="_blank" class="btn" style="margin-top: 1rem; padding: 0.5rem 1rem; font-size: 0.8rem;">${tRequestToAdd}</a>`;
            resultsContainer.appendChild(div);
            resultsContainer.style.display = 'block';
        }
    });

    // Close results when clicking outside
    document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !resultsContainer.contains(e.target)) {
            resultsContainer.style.display = 'none';
        }
    });
</script>

<style>
    .search-pill {
        background-color: var(--surface-color);
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        padding: 0.4rem 0.9rem;
        border-radius: 8px;
        font-size: 0.8rem;
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .search-pill:hover {
        border-color: var(--text-color);
        color: var(--text-color);
    }

    .search-pill.active {
        background-color: var(--text-color);
        border-color: var(--text-color);
        color: var(--bg-color);
    }
</style>
