---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../db/schema';
import { env } from 'cloudflare:workers';
import { desc, asc } from 'drizzle-orm';
import { isWebApp } from '../utils/webapp';
import { getLanguage, useTranslations } from '../i18n';

const db = drizzle(env.DB, { schema });
const lang = getLanguage(Astro.request, Astro.cookies);
const t = useTranslations(lang);

const allApps = (await db.select()
  .from(schema.apps)
  .orderBy(desc(schema.apps.popularity), asc(schema.apps.name))
  .all()).map(app => ({
    ...app,
    isWebApp: isWebApp(app)
  }));

// Filter 5 recently added apps (non-core apps by default, taking the first ones in the standard seed list)
const recentlyAdded = allApps.filter(app => app.popularity === 0).slice(0, 5);

// Filter top apps
const topApps = allApps.filter(app => app.popularity > 0);

const penguinSvg = `<span class="native-badge-pill" style="display: inline-flex; align-items: center; justify-content: center; background-color: var(--bg-color); color: #10b981; padding: 0.15rem 0.4rem; border-radius: 6px; border: 1px solid rgba(16, 185, 129, 0.3); font-weight: 700; gap: 0.2rem; font-family: 'Space Grotesk', sans-serif; font-size: 0.65rem; text-transform: uppercase; margin-left: 0.5rem; vertical-align: middle;" title="Native Linux Support"><i class="fa-brands fa-linux" style="font-size: 1.1em;"></i> Native</span>`;
const webAppSvg = `<span class="webapp-badge-pill" style="display: inline-flex; align-items: center; justify-content: center; background-color: var(--bg-color); color: #3b82f6; padding: 0.15rem 0.4rem; border-radius: 6px; border: 1px solid rgba(59, 130, 246, 0.3); font-weight: 700; gap: 0.2rem; font-family: 'Space Grotesk', sans-serif; font-size: 0.65rem; text-transform: uppercase; margin-left: 0.5rem; vertical-align: middle;" title="Official Web App / Cloud Version Available"><i class="fa-solid fa-cloud" style="font-size: 1em;"></i> Web App</span>`;
---

<Layout title={lang === 'en' ? "ItRunsOnLinux - Switch to Linux with Confidence" : "ItRunsOnLinux - Cambia a Linux con confianza"}>
    <div style="text-align: center; margin-bottom: 3.5rem; margin-top: 2rem;">
        <h1 class="hero-title" style="margin-bottom: 1rem;">
            {t('hero.title')} <span style="color: var(--accent-color);">{t('hero.title.span')}</span>
        </h1>
        <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto; line-height: 1.7; font-weight: 500;">
            {t('hero.subtitle')}
        </p>
    </div>

    <SearchBar />

    <div class="flat-card" style="margin-bottom: 3.5rem; padding: 2rem; border-left: 4px solid var(--accent-color); background-color: var(--surface-color);">
        <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--text-color); margin-bottom: 0.75rem; font-family: 'Space Grotesk', sans-serif; letter-spacing: -0.5px;">
            {t('new.title')}
        </h2>
        <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; max-width: 850px; margin-bottom: 1.5rem;">
            {t('new.desc')}
        </p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="/starter-pack" class="btn">{t('new.btn.starter')} &rarr;</a>
            <a href="/faq" class="btn" style="background-color: transparent; color: var(--text-color) !important; border: 1px solid var(--border-color); box-shadow: none;">{t('new.btn.guide')}</a>
        </div>
    </div>

    <!-- Category Filters -->
    <div style="display: flex; flex-direction: column; align-items: center; gap: 1.25rem; margin-bottom: 2rem;">
        <label style="display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 600; color: var(--text-color); background-color: var(--surface-color); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); font-size: 0.85rem; font-family: 'Space Grotesk', sans-serif;">
            <input type="checkbox" id="native-only-toggle" style="width: 1.1rem; height: 1.1rem; accent-color: var(--accent-color); cursor: pointer;">
            <span> {t('toggle.native')}</span>
        </label>
        <div class="category-filters">
            <button class="category-btn active" data-category="home">{t('cat.home')}</button>
            <button class="category-btn" data-category="all">{t('cat.all')}</button>
            <button class="category-btn" data-category="Design">{t('cat.design')}</button>
            <button class="category-btn" data-category="Office">{t('cat.office')}</button>
            <button class="category-btn" data-category="Games">{t('cat.games')}</button>
            <button class="category-btn" data-category="Social">{t('cat.social')}</button>
            <button class="category-btn" data-category="Development">{t('cat.development')}</button>
            <button class="category-btn" data-category="Audio">{t('cat.audio')}</button>
            <button class="category-btn" data-category="Utilities">{t('cat.utilities')}</button>
            <button class="category-btn" data-category="Windows Integrated">{t('cat.winIntegrated')}</button>
        </div>
    </div>

    <!-- Legend -->
    <div style="margin-bottom: 3rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 1.5rem; font-size: 0.85rem; color: var(--text-muted); padding: 0.75rem 1.5rem; background-color: var(--surface-color); border: 1px solid var(--border-color); border-radius: 8px; max-width: max-content; margin-left: auto; margin-right: auto; box-shadow: var(--card-shadow); font-weight: 500;">
        <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; justify-content: center;">
            <span>{t('legend.desc')} </span>
            <span style="display: inline-flex; align-items: center; justify-content: center; background-color: var(--bg-color); color: #10b981; padding: 0.2rem 0.5rem; border-radius: 6px; border: 1px solid rgba(16, 185, 129, 0.3); font-weight: 700; gap: 0.25rem; font-family: 'Space Grotesk', sans-serif; font-size: 0.7rem; text-transform: uppercase;">
                <i class="fa-brands fa-linux" style="font-size: 1.1em;"></i> Native
            </span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; justify-content: center;">
            <span>{t('legend.webapp')} </span>
            <span style="display: inline-flex; align-items: center; justify-content: center; background-color: var(--bg-color); color: #3b82f6; padding: 0.2rem 0.5rem; border-radius: 6px; border: 1px solid rgba(59, 130, 246, 0.3); font-weight: 700; gap: 0.25rem; font-family: 'Space Grotesk', sans-serif; font-size: 0.7rem; text-transform: uppercase;">
                <i class="fa-solid fa-cloud" style="font-size: 1em;"></i> Web App
            </span>
        </div>
    </div>

    <!-- Dashboard Layout Grid (Shown by default) -->
    <div id="dashboard-grid" class="dashboard-grid">
        <!-- Block 1: Recently Added -->
        <div class="dashboard-col flat-block" style="border: 1px solid var(--border-color); background-color: var(--surface-color); border-radius: 8px; padding: 1.5rem;">
            <h2 class="col-title" style="color: var(--text-color); border-bottom: 1px solid var(--border-color); font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1.3rem; padding-bottom: 0.5rem; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.5px;">{t('recent.title')}</h2>
            <div class="col-list">
                 {recentlyAdded.map(app => (
                    <a href={`/app/${app.id}`} class="dashboard-item" data-native={app.linuxAlternative?.toLowerCase().includes('native') ? "true" : "false"} style="display: block; text-decoration: none;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem;">
                            <span class="app-link">{app.name}{app.linuxAlternative?.toLowerCase().includes('native') && <span set:html={penguinSvg} />}{app.isWebApp && <span set:html={webAppSvg} />}</span>
                        </div>
                        <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem; font-weight: 500;">{t(`cat.${app.category.toLowerCase()}` as any) || app.category}</div>
                    </a>
                ))}
            </div>
        </div>

        <!-- Block 2: Top Software -->
        <div class="dashboard-col flat-block" style="border: 1px solid var(--border-color); background-color: var(--surface-color); border-radius: 8px; padding: 1.5rem;">
            <h2 class="col-title" style="color: var(--text-color); border-bottom: 1px solid var(--border-color); font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1.3rem; padding-bottom: 0.5rem; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.5px;">{t('top.title')}</h2>
            <div class="col-list" id="top-software-list">
                {topApps.map((app, index) => (
                    <a href={`/app/${app.id}`}
                        class="dashboard-item" 
                        style={`display: block; text-decoration: none; ${index >= 10 ? 'display: none;' : ''}`}
                        data-index={index}
                        data-native={app.linuxAlternative?.toLowerCase().includes('native') ? "true" : "false"}
                    >
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; flex-wrap: wrap;">
                            <span class="app-link">{app.name}{app.linuxAlternative?.toLowerCase().includes('native') && <span set:html={penguinSvg} />}{app.isWebApp && <span set:html={webAppSvg} />}</span>
                        </div>
                        <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem; font-weight: 500;">{t(`cat.${app.category.toLowerCase()}` as any) || app.category}</div>
                    </a>
                ))}
            </div>
            {topApps.length > 10 && (
                <div style="text-align: center; margin-top: 1.5rem;">
                    <button id="load-more-top" class="btn" style="background-color: transparent; border: 1px solid var(--border-color); color: var(--text-color) !important; font-size: 0.9rem; padding: 0.5rem 1.5rem; cursor: pointer; border-radius: 8px; font-weight: 600; box-shadow: none;">
                        {t('btn.seeMore')} &darr;
                    </button>
                </div>
            )}
        </div>
    </div>

    <!-- Filtered List Container (Hidden by default) -->
    <div id="filtered-container" style="display: none; background-color: var(--surface-color); border: 1px solid var(--border-color); padding: 2rem; border-radius: 8px; box-shadow: var(--card-shadow);">
        <h2 id="category-title" style="margin-bottom: 0.5rem; font-size: 1.8rem; color: var(--text-color); font-family: 'Space Grotesk', sans-serif; font-weight: 750;">Category</h2>
        <p id="category-count" style="color: var(--text-muted); margin-bottom: 1.5rem; font-size: 0.95rem; font-weight: 500;">Count</p>
        <div id="category-notice" style="display: none; background-color: rgba(59, 130, 246, 0.05); border: 1px solid #3b82f6; border-radius: 8px; padding: 1.25rem 2rem; margin-bottom: 2rem;"></div>
        <div id="filtered-list" style="display: flex; flex-direction: column; gap: 1rem;">
            <!-- Rendered by client script -->
        </div>
    </div>
</Layout>

<style>
    .category-filters {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 3.5rem;
    }

    .category-btn {
        background-color: var(--surface-color);
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        padding: 0.5rem 1.25rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .category-btn:hover {
        border-color: var(--accent-color);
        color: var(--text-color);
    }

    .category-btn.active {
        background-color: var(--accent-color);
        border-color: var(--accent-color);
        color: #fff;
    }

    .dashboard-col {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .flat-block {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        background-color: var(--surface-color);
    }

    .col-title {
        font-size: 1.25rem;
        font-weight: 800;
        padding-bottom: 0.5rem;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .col-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .dashboard-item {
        background-color: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        padding: 1rem;
        transition: border-color 0.2s, background-color 0.2s;
    }

    .dashboard-item:hover {
        border-color: var(--accent-color);
        background-color: var(--surface-hover);
    }

    .app-link {
        font-weight: 700;
        color: var(--text-color);
        transition: color 0.2s;
        text-decoration: none;
    }

    .app-link:hover {
        color: var(--accent-color);
    }

    .web-link {
        font-size: 0.8rem;
        text-decoration: underline;
        white-space: nowrap;
        font-weight: 600;
    }

    .accent-link {
        color: var(--accent-color);
    }

    .accent-link:hover {
        color: var(--accent-hover);
    }

    body.native-only .dashboard-item:not([data-native="true"]),
    body.native-only .flat-card:not([data-native="true"]) {
        display: none !important;
    }

    @media (max-width: 768px) {
        .columns-split {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }
</style>

<script define:vars={{
    apps: allApps,
    penguinSvg,
    webAppSvg,
    tAllSoftware: t('cat.all'),
    tGamesNoticeTitle: t('games.notice.title'),
    tGamesNoticeDesc1: t('games.notice.desc1'),
    tGamesNoticeDesc2: t('games.notice.desc2'),
    tNoSoftware: t('no.software'),
    tSeeMore: t('btn.seeMore'),
    tViewDetails: t('app.details'),
    tFoundSuffix: t('cat.found'),
    tCategories: {
        'all': t('cat.all'),
        'Design': t('cat.design'),
        'Office': t('cat.office'),
        'Games': t('cat.games'),
        'Social': t('cat.social'),
        'Development': t('cat.development'),
        'Audio': t('cat.audio'),
        'Utilities': t('cat.utilities'),
        'Windows Integrated': t('cat.winIntegrated')
    }
}}>
    const categoryButtons = document.querySelectorAll('.category-btn');
    const dashboardGrid = document.getElementById('dashboard-grid');
    const filteredContainer = document.getElementById('filtered-container');
    const filteredList = document.getElementById('filtered-list');
    const categoryTitle = document.getElementById('category-title');
    const categoryCount = document.getElementById('category-count');
    const categoryNotice = document.getElementById('category-notice');
    const nativeOnlyToggle = document.getElementById('native-only-toggle');

    if (nativeOnlyToggle) {
        nativeOnlyToggle.addEventListener('change', (e) => {
            if (e.target.checked) {
                document.body.classList.add('native-only');
            } else {
                document.body.classList.remove('native-only');
            }
            
            // Re-trigger the active category to update the lists properly
            const activeCategory = document.querySelector('.category-btn.active');
            if (activeCategory && activeCategory.getAttribute('data-category') !== 'home') {
                activeCategory.click();
            }
        });
    }

    // Top Software Load More Handler
    const loadMoreTopBtn = document.getElementById('load-more-top');
    if (loadMoreTopBtn) {
        let currentVisibleTop = 10;
        loadMoreTopBtn.addEventListener('click', () => {
            const items = document.querySelectorAll('#top-software-list .dashboard-item');
            let newlyShown = 0;
            const isNativeOnly = nativeOnlyToggle && nativeOnlyToggle.checked;
            
            for (let i = currentVisibleTop; i < items.length && newlyShown < 10; i++) {
                items[i].style.display = 'block';
                if (!isNativeOnly || items[i].getAttribute('data-native') === 'true') {
                    newlyShown++;
                }
                currentVisibleTop = i + 1;
            }
            if (currentVisibleTop >= items.length) {
                loadMoreTopBtn.style.display = 'none';
            }
        });
    }

    categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            categoryButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const category = btn.getAttribute('data-category');

            if (category === 'home') {
                dashboardGrid.style.display = 'grid';
                filteredContainer.style.display = 'none';
                
                // Reset category load more button if any
                const existingBtn = document.getElementById('load-more-filtered');
                if (existingBtn) {
                    existingBtn.remove();
                }
            } else {
                dashboardGrid.style.display = 'none';
                filteredContainer.style.display = 'block';
                
                if (category === 'all') {
                    categoryTitle.textContent = tAllSoftware;
                } else {
                    categoryTitle.textContent = tCategories[category] || category;
                }

                // Handle special notice for Games
                if (category === 'Games') {
                    categoryNotice.style.display = 'block';
                    categoryNotice.innerHTML = `
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <div>
                                <strong style="color: var(--text-color); display: block; margin-bottom: 0.25rem; font-size: 1.05rem;">${tGamesNoticeTitle}</strong>
                                <span style="color: var(--text-muted); line-height: 1.6; font-size: 0.95rem;">${tGamesNoticeDesc1} <a href="https://www.protondb.com" target="_blank" style="color: var(--accent-color); font-weight: 700; text-decoration: underline;">ProtonDB</a>${tGamesNoticeDesc2}</span>
                            </div>
                        </div>
                    `;
                } else {
                    categoryNotice.style.display = 'none';
                    categoryNotice.innerHTML = '';
                }

                filteredList.innerHTML = '';
                
                const isNativeOnly = nativeOnlyToggle && nativeOnlyToggle.checked;
                let filtered = [];
                if (category === 'all') {
                    filtered = [...apps].sort((a, b) => a.name.localeCompare(b.name));
                } else {
                    filtered = apps.filter(app => app.category === category);
                }
                
                if (isNativeOnly) {
                    filtered = filtered.filter(app => app.linuxAlternative && app.linuxAlternative.toLowerCase().includes('native'));
                }
                
                categoryCount.textContent = `${filtered.length} ${tFoundSuffix}`;

                let visibleFilteredCount = 10;
                
                    const renderNextFilteredBatch = () => {
                        const batch = filtered.slice(visibleFilteredCount - 10, visibleFilteredCount);
                        batch.forEach(app => {
                            const isNative = app.linuxAlternative && app.linuxAlternative.toLowerCase().includes('native');
                            const nativeIconHtml = isNative ? penguinSvg : '';
                            const webAppIconHtml = app.isWebApp ? webAppSvg : '';

                            const a = document.createElement('a');
                            a.href = `/app/${app.id}`;
                            a.className = 'filtered-app-card';
                            a.setAttribute('data-native', isNative ? "true" : "false");
                            
                            a.innerHTML = `
                                <div style="display: flex; flex-direction: column; gap: 0.25rem; flex: 1; text-align: left;">
                                    <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
                                        <h3 style="color: var(--text-color); font-size: 1.25rem; font-weight: 700; margin: 0;">${app.name}${nativeIconHtml}${webAppIconHtml}</h3>
                                        <span style="font-size: 0.75rem; border: 1px solid var(--border-color); padding: 0.15rem 0.5rem; border-radius: 4px; color: var(--text-muted); font-weight: 600; text-transform: uppercase;">
                                            ${tCategories[app.category] || app.category}
                                        </span>
                                    </div>
                                    <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.5; margin: 0;">
                                        ${app.description}
                                    </p>
                                </div>
                                <div style="color: var(--accent-color); font-size: 0.95rem; font-weight: 600; white-space: nowrap;">
                                    ${tViewDetails} &rarr;
                                </div>
                            `;
                        filteredList.appendChild(a);
                    });

                    // Remove existing load more button in the container if any
                    const existingBtn = document.getElementById('load-more-filtered');
                    if (existingBtn) {
                        existingBtn.remove();
                    }

                    if (visibleFilteredCount < filtered.length) {
                        const btnDiv = document.createElement('div');
                        btnDiv.id = 'load-more-filtered';
                        btnDiv.style.cssText = 'text-align: center; margin-top: 1.5rem; margin-bottom: 2rem;';
                        btnDiv.innerHTML = `
                            <button class="btn" style="background-color: transparent; border: 1px solid var(--border-color); color: var(--text-color) !important; font-size: 0.9rem; padding: 0.5rem 1.5rem; cursor: pointer; border-radius: 8px; font-weight: 600; box-shadow: none;">
                                ${tSeeMore} &darr;
                            </button>
                        `;
                        btnDiv.querySelector('button').addEventListener('click', () => {
                            visibleFilteredCount += 10;
                            renderNextFilteredBatch();
                        });
                        filteredContainer.appendChild(btnDiv);
                    }
                };

                if (filtered.length > 0) {
                    renderNextFilteredBatch();
                } else {
                    filteredList.innerHTML = `<div style="text-align: center; padding: 3rem; color: var(--text-muted);">${tNoSoftware}</div>`;
                    const existingBtn = document.getElementById('load-more-filtered');
                    if (existingBtn) {
                        existingBtn.remove();
                    }
                }
            }
        });
    });
</script>
