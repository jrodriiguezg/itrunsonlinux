---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import StatsBar from '../components/StatsBar.astro';
import { getLanguage, useTranslations } from '../i18n';

const lang = getLanguage(Astro.request, Astro.cookies);
const t = useTranslations(lang);
---

<Layout title={lang === 'en' ? "ItRunsOnLinux - Switch to Linux with Confidence" : "ItRunsOnLinux - Cambia a Linux con confianza"}>
    <div style="text-align: center; margin-bottom: 3.5rem; margin-top: 2rem;">
        <h1 class="hero-title" style="margin-bottom: 1rem;">
            {t('hero.title')} <span style="color: var(--accent-color);">{t('hero.title.span')}</span>
        </h1>
        <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto; line-height: 1.7; font-weight: 500;">
            {t('hero.subtitle')}
        </p>
    </div>

    <StatsBar />

    <SearchBar />

    <div class="flat-card" style="margin-bottom: 3.5rem; padding: 2rem; border-left: 4px solid var(--accent-color); background-color: var(--surface-color);">
        <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--text-color); margin-bottom: 0.75rem; font-family: 'Space Grotesk', sans-serif; letter-spacing: -0.5px;">
            {t('new.title')}
        </h2>
        <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; max-width: 850px; margin-bottom: 1.5rem;">
            {t('new.desc')}
        </p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="/starter-pack" class="btn">{t('new.btn.starter')} &rarr;</a>
            <a href="/faq" class="btn" style="background-color: transparent; color: var(--text-color) !important; border: 1px solid var(--border-color); box-shadow: none;">{t('new.btn.guide')}</a>
        </div>
    </div>

    <div style="text-align: center; margin-top: 2rem;">
        <a href="/explore" class="btn" style="padding: 0.8rem 2rem; font-size: 1rem;">
            {lang === 'en' ? 'Explore All Software' : 'Explorar Todo el Software'} &rarr;
        </a>
    </div>
</Layout>
