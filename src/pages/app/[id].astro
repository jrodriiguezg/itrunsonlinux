  return mapping[cleanKey];
};
---

<Layout title={`${app.name} on Linux - ItRunsOnLinux`}>
    <div style="margin-bottom: 2rem;">
        <a href="/" style="color: var(--text-muted); font-size: 0.9rem; font-weight: 600; text-decoration: none;">&larr; Back to home</a>
    </div>

    <div class="flat-card" style="margin-bottom: 3rem; display: flex; flex-direction: column; gap: 1rem;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
            <div>
                <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: var(--text-color); font-weight: 800; letter-spacing: -0.5px;">{app.name}</h1>
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <span style="font-size: 0.9rem; border: 1px solid var(--border-color); padding: 0.25rem 0.75rem; border-radius: 4px; color: var(--text-muted);">
                        {app.category}
                    </span>
                    <button id="upvote-btn" data-appid={app.id} style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; background-color: var(--surface-color); border: 1px solid var(--border-color); padding: 0.25rem 0.75rem; border-radius: 4px; color: var(--text-color); cursor: pointer; transition: all 0.2s;">
                        <span style="color: var(--accent-color);">▲</span>
                        <span id="upvote-count">{app.popularity || 0}</span>
                    </button>
                </div>
            </div>
            {app.homepage && (
                <a href={app.homepage} target="_blank" class="btn" style="padding: 0.6rem 1.25rem;">
                    Official Page &rarr;
                </a>
            )}
        </div>
        <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 800px; margin-top: 1rem; line-height: 1.6;">
            {app.description}
        </p>
    </div>

    {isNative ? (
        <div style="margin-bottom: 3rem;">
            <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; font-weight: 700;">
                Linux Support
            </h2>
            <div class="flat-card" style="padding: 1.5rem; border-left: 4px solid #10b981;">
