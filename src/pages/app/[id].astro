---
import Layout from '../../layouts/Layout.astro';
import { drizzle } from 'drizzle-orm/d1';
import * as schema from '../../db/schema';
import { eq } from 'drizzle-orm';
import { env } from 'cloudflare:workers';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

const db = drizzle(env.DB, { schema });

const app = await db.select().from(schema.apps).where(eq(schema.apps.id, id)).get();
if (!app) return Astro.redirect('/');

const appReports = await db.select().from(schema.reports).where(eq(schema.reports.appId, id)).all();

const isNativeApp = app.linuxAlternative && app.linuxAlternative.toLowerCase().includes('native linux version');

const canRunWithWine = appReports.some(
  (r) => r.runner.toLowerCase() !== 'native' && r.rating.toLowerCase() !== 'garbage'
);

const isNative = isNativeApp || appReports.some(
  (r) => r.runner.toLowerCase() === 'native' || r.rating.toLowerCase() === 'native'
);

const isGarbage = appReports.length > 0 && appReports.every(
  (r) => r.rating.toLowerCase() === 'garbage'
);

const recommendedRunner = appReports.find(
  (r) => r.runner.toLowerCase() !== 'native' && r.rating.toLowerCase() !== 'garbage'
)?.runner;

const alternativeNames = app.linuxAlternative && !isNativeApp
  ? app.linuxAlternative.split(/\s*\/\s*/).map(name => name.trim()).filter(Boolean)
  : [];

const nativeParts = app.linuxAlternative ? app.linuxAlternative.split('|') : [];
const githubUrl = nativeParts.find((p: string) => p.startsWith('github:'))?.split('github:')[1];
const storedFlathubId = nativeParts.find((p: string) => p.startsWith('flathub:'))?.split('flathub:')[1];

const alternativeUrls: Record<string, string> = {
  'gimp': 'https://www.gimp.org',
  'krita': 'https://krita.org',
  'inkscape': 'https://inkscape.org',
  'scribus': 'https://www.scribus.net',
  'davinci resolve': 'https://www.blackmagicdesign.com/products/davinciresolve',
  'kdenlive': 'https://kdenlive.org',
  'natron': 'https://natrongithub.github.io',
  'blender': 'https://www.blender.org',
  'darktable': 'https://www.darktable.org',
  'rawtherapee': 'https://www.rawtherapee.com',
