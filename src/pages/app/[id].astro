<script>
    const upvoteBtn = document.getElementById('upvote-btn');
    const upvoteCount = document.getElementById('upvote-count');
    
    if (upvoteBtn && upvoteCount) {
        const appId = upvoteBtn.dataset.appid;
        const votedKey = `voted_${appId}`;
        
        if (localStorage.getItem(votedKey)) {
            upvoteBtn.style.opacity = '0.5';
            upvoteBtn.style.cursor = 'default';
            upvoteBtn.title = 'You have already upvoted this app';
        } else {
            upvoteBtn.addEventListener('click', async () => {
                try {
                    const res = await fetch('/api/upvote', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ appId })
                    });
                    
                    if (res.ok) {
                        localStorage.setItem(votedKey, 'true');
                        upvoteCount.textContent = (parseInt(upvoteCount.textContent || '0') + 1).toString();
                        upvoteBtn.style.opacity = '0.5';
                        upvoteBtn.style.cursor = 'default';
                        upvoteBtn.title = 'You have already upvoted this app';
                        
                        // Replace element to remove listeners
                        const newBtn = upvoteBtn.cloneNode(true);
                        upvoteBtn.parentNode.replaceChild(newBtn, upvoteBtn);
                    }
                } catch (err) {
                    console.error('Failed to upvote', err);
                }
            });
        }
    }
</script>
