                <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.6; margin-bottom: 1.25rem;">
                    Good news! <strong>{app.name}</strong> is natively supported on Linux. You do not need to run it through compatibility layers like Wine.
                </p>
                <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
                    {app.homepage && (
                        <a href={app.homepage} target="_blank" class="btn" style="background-color: #10b981; border-color: #10b981; padding: 0.5rem 1.25rem;">
                            Visit Official Website &rarr;
                        </a>
                    )}
                    {githubUrl && (
                        <a href={githubUrl} target="_blank" class="btn" style="background-color: #333; border-color: #333; padding: 0.5rem 1.25rem; color: white; text-decoration: none;">
                            View Source on GitHub &rarr;
                        </a>
                    )}
                    {(storedFlathubId || getAppStreamId(app.name)) && (
                        <a href={`https://flathub.org/apps/${storedFlathubId || getAppStreamId(app.name)}`} target="_blank" class="btn" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-color); color: var(--accent-color); padding: 0.5rem 1.25rem; font-weight: 700; text-decoration: none;">
                            Open in Flathub &rarr;
                        </a>
                    )}
                </div>
            </div>
        </div>
    ) : (
        <>
            <div style="margin-bottom: 3rem;">
                <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; font-weight: 700;">
                    Recommended Linux Alternatives
                </h2>

                {alternativeNames.length === 0 ? (
                    <div style="text-align: center; padding: 3rem 2rem; background-color: var(--surface-color); border: 1px dashed var(--border-color); border-radius: 8px; color: var(--text-muted);">
                        <p style="font-size: 1.05rem; margin: 0;">No specific Linux alternatives are listed for this application.</p>
                    </div>
                ) : (
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        {alternativeNames.map(name => {
                            const url = alternativeUrls[name.toLowerCase()];
                            const appStreamId = getAppStreamId(name);
                            return (
                                <div class="flat-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-left: 4px solid #10b981; flex-wrap: wrap; gap: 1rem;">
                                    <div>
                                        <h3 style="color: var(--text-color); font-size: 1.25rem; font-weight: 700; margin: 0 0 0.25rem 0;">{name}</h3>
                                        <span style="font-size: 0.75rem; border: 1px solid rgba(16, 185, 129, 0.3); padding: 0.15rem 0.5rem; border-radius: 4px; color: #10b981; font-weight: 600; text-transform: uppercase;">
                                            Native Alternative
                                        </span>
                                    </div>
                                    <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
                                        {url ? (
                                            <a href={url} target="_blank" class="btn" style="background-color: #10b981; border-color: #10b981; padding: 0.5rem 1.25rem;">
                                                Visit Website &rarr;
                                            </a>
                                        ) : (
                                            <span style="font-size: 0.95rem; color: var(--text-muted); font-weight: 600; margin-right: 0.5rem;">Open Source</span>
                                        )}
                                        {appStreamId && (
                                            <a href={`appstream://${appStreamId}`} class="btn" style="background-color: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-color); color: var(--accent-color); padding: 0.5rem 1.25rem; font-weight: 700; text-decoration: none;">
                                                Open in Store &rarr;
                                            </a>
                                        )}
                                    </div>
