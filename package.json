{
  "name": "awesome-antimatter",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "db:studio": "DB_LOCAL_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject/ -type f -name \"*.sqlite\" ! -name \"metadata.sqlite\" | head -n 1) npx drizzle-kit studio"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "astro": "^6.4.6",
    "drizzle-orm": "^0.45.2",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "better-sqlite3": "^12.10.1",
    "drizzle-kit": "^0.31.10"
  }
}
